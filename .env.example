
# 多语言路径配置
# 中文路径: 无前缀 (SEO 友好)
# 英文路径: 带 /en 前缀
NEXT_PUBLIC_DEFAULT_LOCALE=zh
NEXT_PUBLIC_SUPPORTED_LOCALES=zh,en

# 语言路径前缀配置
NEXT_PUBLIC_ENGLISH_PATH_PREFIX=/en
NEXT_PUBLIC_CHINESE_PATH_PREFIX=

# GraphQL 查询语言参数
NEXT_PUBLIC_GRAPHQL_LANGUAGE_ZH=ZH
NEXT_PUBLIC_GRAPHQL_LANGUAGE_EN=EN

# 应用配置
NEXT_PUBLIC_SITE_NAME=DLEngine
NEXT_PUBLIC_SITE_DESCRIPTION=现代化企业官网

# 部署配置
NEXT_PUBLIC_SITE_URL=https://www.dlengine.com

# 多语言 SEO 配置
NEXT_PUBLIC_CANONICAL_URL=https://www.dlengine.com
NEXT_PUBLIC_ENGLISH_CANONICAL_URL=https://www.dlengine.com/en